<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:ShuttleBookingApp.Presentation.Components"
             xmlns:viewModels="clr-namespace:ShuttleBookingApp.Presentation.ViewModels"
             x:Class="ShuttleBookingApp.Presentation.Pages.Login.LoginPage"
             NavigationPage.HasNavigationBar="False" x:DataType="viewModels:LoginViewModel">
    <ContentPage.Content>

        <Frame BorderColor="{StaticResource LightBackgroundGray}"
               WidthRequest="300"
               HeightRequest="600">

            <StackLayout Spacing="15"
                         HorizontalOptions="Center"
                         VerticalOptions="Center">

                <components:TitlePageComponent
                    Text="Login"
                    HorizontalOptions="Center"
                    Margin="0"
                    Padding="0"
                    TextColor="{StaticResource Black}" />

                <Entry Placeholder="email"
                       WidthRequest="200"
                       Text="{Binding Email}" />

                <Entry Placeholder="password"
                       IsPassword="True"
                       WidthRequest="200"
                       Text="{Binding Password}" />

                <Button Text="Login"
                        BackgroundColor="{StaticResource Green}"
                        WidthRequest="150"
                        Margin="0,5,0,-10"
                        Command="{Binding LoginCommand}"
                        IsEnabled="{Binding IsNotBusy}" />

                <Button Text="Crea account"
                        BackgroundColor="{StaticResource Blue}"
                        WidthRequest="150"
                        Margin="0,5,0,-10"
                        Command="{Binding CreateAccountCommand}"
                        IsEnabled="{Binding IsNotBusy}" />

                <Button Text="Accedi con Google"
                        BackgroundColor="{StaticResource Red}"
                        Margin="0,5,0,0"
                        Command="{Binding GoogleLoginCommand}"
                        IsEnabled="{Binding IsNotBusy}" />

                <!-- Indicatore di attività -->
                <Grid IsVisible="{Binding IsBusy}" Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   Color="{StaticResource Blue}"
                                   HeightRequest="40"
                                   WidthRequest="40" />
                    <Label Text="Attendere..." 
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Gray4}" 
                           FontSize="12"
                           Margin="0,40,0,0"/>
                </Grid>
            </StackLayout>
        </Frame>
    </ContentPage.Content>
</ContentPage>