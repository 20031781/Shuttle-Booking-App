<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:ShuttleBookingApp.Presentation.Components"
             xmlns:viewModels="clr-namespace:ShuttleBookingApp.Presentation.ViewModels"
             x:Class="ShuttleBookingApp.Presentation.Pages.Shuttle.ShuttleListPage"
             x:DataType="viewModels:ShuttleListViewModel">

    <ContentPage.Content>
        <Grid Margin="20,0,20,20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <components:TitlePageComponent Grid.Row="0" TextColor="{StaticResource Blue}" Text="Navette esistenti" />

            <CollectionView Grid.Row="1" ItemsSource="{Binding Shuttles}">
                <CollectionView.ItemTemplate>

                    <DataTemplate>
                        <components:ShuttleCardComponent TextColor="{StaticResource Blue}" />
                    </DataTemplate>

                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </ContentPage.Content>
</ContentPage>