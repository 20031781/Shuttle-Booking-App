<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ShuttleBookingApp.Presentation.Components"
             xmlns:models="clr-namespace:ShuttleBookingApp.Business.Models;assembly=ShuttleBookingApp.Business"
             x:Class="ShuttleBookingApp.Presentation.Components.ShuttleCardComponent" x:DataType="models:Shuttle">

    <Frame>
        <Grid Padding="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Image Source="shuttle_van.png" WidthRequest="50" HeightRequest="50" Grid.RowSpan="3"
                   Grid.Column="0" VerticalOptions="Center" Margin="0,0,10,0" />

            <Label Grid.Row="1" Grid.Column="1" HorizontalOptions="Start">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Nome: " FontAttributes="Bold"
                              TextColor="{Binding TextColor, Source={RelativeSource AncestorType={x:Type local:ShuttleCardComponent}}}" />
                        <Span Text="{Binding Name}" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Label Grid.Row="2" Grid.Column="1" HorizontalOptions="Start">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Capacità: " FontAttributes="Bold"
                              TextColor="{Binding TextColor, Source={RelativeSource AncestorType={x:Type local:ShuttleCardComponent}}}" />
                        <Span Text="{Binding Capacity}" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
        </Grid>
    </Frame>
</ContentView>